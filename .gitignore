# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
# Python build artifacts (scoped to avoid affecting frontend/src/lib)
**/lib/
**/lib64/
# ...but the frontend source lib dir is NOT a build artifact — keep it tracked.
!frontend/src/lib/
!frontend/src/lib/**
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
env/
ENV/
.venv/

# Local configs and artifacts (per-app)
# tests.json holds operational state and may contain REAL tokens/credentials.
# Keep it local; commit config/tests.example.json instead.
config/tests.json
config/*.local.json

# Backend (FastAPI) also stores operational state relative to its cwd
backend/config/tests.json
backend/config/*.local.json
*.log
results/

# Old/legacy progress (kept for history)
otp_progress.txt
config.json

# Local env (ports). Committed template lives in .env.example
.env

# IDE / tooling
.vscode/
.idea/
*.swp
*.swo
.grok/

# OS
.DS_Store
Thumbs.db

# Dependencies
**/node_modules/

# VitePress build cache / output (regenerated on each docs run)
docs/.vitepress/cache/
docs/.vitepress/dist/

# Rust / Tauri build artifacts
**/target/
# Bundled Python sidecars (produced by npm run desktop:prepare)
frontend/src-tauri/backend-*
frontend/src-tauri/mcp_server-*
frontend/src-tauri/binaries/
# PyInstaller build output (regenerated by build_backend.py every build)
backend/dist/
backend/build/
backend/backend.spec
